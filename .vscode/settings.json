{
  // Для SCSS ставим стандартный форматтер Stylelint
  "[scss]": {
    "editor.defaultFormatter": "stylelint.vscode-stylelint",
    "editor.formatOnSave": true
  },

  // Для Vue ставим в качестве форматтера Prettier (или Volar, если пользуешься им)
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ВОТ ЭТО САМАЯ ВАЖНАЯ ЧАСТЬ: она заставляет линтеры исправлять отступы, пустые строки и точки с запятой
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.fixAll.stylelint": "always"
  },

  "css.validate": false,
  "less.validate": false,
  "scss.validate": false
}
