{
  "printWidth": 200,
  "singleAttributePerLine": true,
  "htmlWhitespaceSensitivity": "ignore",
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.html", "*.hbs", "*.vue"],
      "options": {
        "printWidth": 120
      }
    }
  ]
}
